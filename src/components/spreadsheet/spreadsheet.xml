<templates>
  <t t-name="o-spreadsheet-Spreadsheet">
    <div
      class="o-spreadsheet h-100 w-100"
      t-att-class="getSpreadSheetClasses()"
      t-ref="spreadsheet"
      t-att-style="getStyle()">
      <div class="o-spreadsheet-topbar-wrapper o-two-columns">
        <TopBar onClick="this.focusGrid" dropdownMaxHeight="gridHeight"/>
      </div>

      <div
        class="d-flex w-100 flex-grow-1 overflow-hidden"
        t-att-class="{'o-two-columns': !sidePanel.isMainPanelOpen}">
        <SpreadsheetPane
          t-key="'left'"
          sheetId="leftSheetId"
          paneId="'left'"
          isFocused="!splitViewStore.isSplitView || splitViewStore.focusedPane === 'left'"
          onFocus="this.focusLeftPane"
          exposeFocusGrid="(focus) => this.paneFocusGrids.left = focus"
        />

        <t t-if="splitViewStore.isSplitView">
          <div class="border-start border-2 border-dark"/>
          <SpreadsheetPane
            t-key="'right'"
            sheetId="rightSheetId"
            paneId="'right'"
            isFocused="splitViewStore.focusedPane === 'right'"
            onFocus="this.focusRightPane"
            exposeFocusGrid="(focus) => this.paneFocusGrids.right = focus"
          />
        </t>
      </div>
      <SidePanels/>
    </div>
  </t>
</templates>
