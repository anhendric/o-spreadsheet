<templates>
  <t t-name="o-spreadsheet-SpreadsheetPane">
    <div
      class="o-spreadsheet-pane d-flex flex-column h-100 w-100"
      t-att-class="{'o-focused': props.isFocused}"
      t-ref="pane"
      t-on-click="this.focusGrid">
      <t t-if="activeCustomFunction">
        <div class="o-cf-full-editor-container flex-grow-1 overflow-hidden">
          <CustomFunctionFullEditor functionName="activeCustomFunction"/>
        </div>
      </t>
      <t t-elif="activeWhiteboard">
        <div class="o-whiteboard-full-editor-container flex-grow-1 overflow-hidden">
          <WhiteboardFullEditor whiteboardId="activeWhiteboard"/>
        </div>
      </t>
      <t t-else="">
        <div
          class="o-grid-container flex-grow-1"
          t-ref="gridContainer"
          t-att-class="{'o-two-columns': !sidePanel.isMainPanelOpen}"
          t-att-style="gridContainerStyle">
          <div class="o-top-left"/>
          <div class="o-column-groups o-zoomable">
            <HeaderGroupContainer layers="colLayers" dimension="'COL'"/>
          </div>
          <div class="o-row-groups o-zoomable">
            <HeaderGroupContainer layers="rowLayers" dimension="'ROW'"/>
          </div>
          <div class="o-group-grid overflow-hidden">
            <Grid
              isFocused="props.isFocused"
              exposeFocus="(focus) => { this._focusGrid = focus; this.props.exposeFocusGrid(focus); }"
              getGridSize.bind="getGridSize"
            />
          </div>
        </div>
      </t>
      <div class="o-spreadsheet-bottombar-wrapper o-two-columns overflow-hidden">
        <SmallBottomBar t-if="env.isSmall" onClick="() => this.focusGrid()"/>
        <BottomBar t-else="" onClick="() => this.focusGrid()"/>
      </div>
    </div>
  </t>
</templates>
